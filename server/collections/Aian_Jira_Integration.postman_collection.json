{
  "info": {
    "name": "Aian - Jira Integration",
    "description": "Postman collection to test the Jira OAuth flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Jira Install (Redirect)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/integrations/jira/install?organizationEyeId={{organizationEyeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "integrations",
            "jira",
            "install"
          ],
          "query": [
            {
              "key": "organizationEyeId",
              "value": "{{organizationEyeId}}",
              "description": "The ID of the OrganizationEye from the DB"
            }
          ]
        },
        "description": "Note: This endpoint is normally opened in a browser because it redirects the user to the Atlassian OAuth consent screen. It won't return JSON."
      },
      "response": []
    },
    {
      "name": "2. Jira Callback (Token Exchange)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "if (jsonData.success && jsonData.data && jsonData.data.connectionId) {",
              "    pm.collectionVariables.set(\"connectionId\", jsonData.data.connectionId);",
              "    console.log(\"Saved connectionId: \" + jsonData.data.connectionId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/integrations/jira/callback?code=REPLACE_WITH_CODE&state={{encodedState}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "integrations",
            "jira",
            "callback"
          ],
          "query": [
            {
              "key": "code",
              "value": "REPLACE_WITH_CODE",
              "description": "The OAuth code returned by Atlassian in the redirect URL"
            },
            {
              "key": "state",
              "value": "{{encodedState}}",
              "description": "The base64 encoded state containing orgEyeId"
            }
          ]
        },
        "description": "Simulates the redirect from Atlassian. Paste the `code` and `state` you get from the browser URL."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:12345",
      "type": "string"
    },
    {
      "key": "organizationEyeId",
      "value": "REPLACE_WITH_ORG_EYE_ID",
      "type": "string"
    },
    {
      "key": "encodedState",
      "value": "REPLACE_WITH_ENCODED_STATE",
      "type": "string"
    },
    {
      "key": "connectionId",
      "value": "",
      "type": "string"
    }
  ]
}
